		"@uploadthing/svelte": "^7.3.3",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"better-auth": "^1.4.18",
		"http-proxy": "^1.18.1",
		"konva": "^10.2.0",
		"mp4-muxer": "^5.2.2",
		"pg": "^8.20.0",
		"sharp": "^0.34.5",
		"socket.io-client": "^4.8.3",
		"stripe": "^20.4.1",
		"uploadthing": "^7.7.4",
		"zod": "^4.3.6"
	}
}
