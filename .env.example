# ──────────────────────────────────────────────────────────────────────
# 3AlarmLabs Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy to .env and fill in real values.
#
# TWO MODES:
#
#   1. FULL DOCKER (`docker compose up --build`)
#      - All services in containers behind Nginx on port 80.
#      - Browser opens http://localhost
#      - docker-compose.yml overrides DATABASE_URL, REDIS_URL, ORIGIN,
#        and BETTER_AUTH_BASE_URL at runtime, so the values below only
#        matter for local CLI tools (drizzle-kit, etc.).
#
#   2. LOCAL DEV (hot reload via `docker compose -f docker-compose.dev.yml up --build`)
#      - Frontend runs Vite dev server with hot reload
#      - API runs tsx watch with hot reload
#      - Source directories are volume-mounted
# ──────────────────────────────────────────────────────────────────────

# Shared database — points to the Docker postgres container
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/threealarmlabs"
TRAINER_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/threealarmlabs"

# Better Auth (generate a strong random secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=""
BETTER_AUTH_BASE_URL="http://localhost"

# Email
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@3alarmlabs.com"

# Stripe (create recurring Prices in Dashboard, then paste IDs)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_INDIVIDUAL_MONTHLY=""
STRIPE_PRICE_INDIVIDUAL_ANNUAL=""
STRIPE_PRICE_TEAM_MONTHLY=""
STRIPE_PRICE_TEAM_ANNUAL=""
STRIPE_PRICE_INSTRUCTOR_MONTHLY=""
STRIPE_PRICE_INSTRUCTOR_ANNUAL=""

# UploadThing
UPLOADTHING_TOKEN=""

# Google Maps
PUBLIC_GOOGLE_MAPS_API_KEY=""

# Trainer API
API_PORT="4000"
REDIS_URL="redis://localhost:6379"

# CORS — comma-separated list of allowed origins (production domain + local dev)
CORS_ORIGIN="http://localhost:5173,http://localhost"

# OpenAI (Whisper transcription + GPT command parsing)
OPENAI_API_KEY=""
