# ──────────────────────────────────────────────────────────────────────
# 3AlarmLabs Environment Variables (example)
# ──────────────────────────────────────────────────────────────────────
# Copy to .env and fill in real values.
#
# LOCAL DEV NOTES
# - Frontend (`frontend/`) uses the repo root `.env` via `kit.env.dir`.
# - API (`api/`) loads repo root `.env` via `dotenv` on startup.
# ──────────────────────────────────────────────────────────────────────

# Shared database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/threealarmlabs"
TRAINER_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/threealarmlabs"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_BASE_URL=""

# Email
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@3alarmlabs.com"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# New pricing tiers (firehouse tiers are annual-only)
STRIPE_PRICE_INDIVIDUAL_MONTHLY=""
STRIPE_PRICE_INDIVIDUAL_ANNUAL=""
STRIPE_PRICE_SMALL_FIREHOUSE_ANNUAL=""
STRIPE_PRICE_MEDIUM_FIREHOUSE_ANNUAL=""
STRIPE_PRICE_LARGE_FIREHOUSE_ANNUAL=""

# Legacy price IDs (optional, for mapping existing subscriptions during transition)
STRIPE_PRICE_TEAM_MONTHLY=""
STRIPE_PRICE_TEAM_ANNUAL=""
STRIPE_PRICE_INSTRUCTOR_MONTHLY=""
STRIPE_PRICE_INSTRUCTOR_ANNUAL=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_ANNUAL=""

# UploadThing
UPLOADTHING_TOKEN=""

# Google Maps
PUBLIC_GOOGLE_MAPS_API_KEY=""

# Trainer API
API_PORT="4000"
REDIS_URL="redis://localhost:6379"
CORS_ORIGIN="http://localhost:5173,http://localhost"

# OpenAI
OPENAI_API_KEY=""

